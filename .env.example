# ============================================================
# SmartEval — Environment Variable Template
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Required
# ------------------------------------------------------------

# OpenAI API key — used by the translator, all experiments,
# and the demo chatbot backend.
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# Optional — LLM selection
# ------------------------------------------------------------

# Which OpenAI model to use when the model is not specified
# as a CLI argument. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# Anthropic API key — only needed if you pass an Anthropic
# model name (e.g. claude-3-5-sonnet-20241022) to the
# translator. Not required for benchmark reproduction.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------
# Optional — pipeline implementation switch
# ------------------------------------------------------------

# Set to "false" to use the legacy agentic_implementation.py
# instead of the default contract-translator/core/ package.
# USE_MODULAR_CORE=true

# ------------------------------------------------------------
# Optional — on-chain deployment (Phase 6 of the demo only)
# These are NOT required to reproduce any benchmark results.
# ------------------------------------------------------------

# JSON-RPC endpoint for a local Ganache instance or a
# testnet (e.g. Infura/Alchemy). Example: http://127.0.0.1:8545
# RPC_URL=http://127.0.0.1:8545

# Ethereum address of the already-deployed contract to interact with.
# CONTRACT_ADDRESS=0xYourContractAddressHere

# Ethereum address that will send transactions.
# ACCOUNT_ADDRESS=0xYourAccountAddressHere

# Private key for the ACCOUNT_ADDRESS (hex, without 0x prefix).
# Never commit a real private key — use a throwaway Ganache key.
# PRIVATE_KEY=your_ganache_private_key_here
